// ─────────────────────────────────────────────────────────────────────────────
// MODEL Booking — додано поля isCompleted та completedAt для SaaS-обліку
// ─────────────────────────────────────────────────────────────────────────────

model Booking {
  id                    Int               @id @default(autoincrement())
  uid                   String            @unique
  idempotencyKey        String?           @unique
  user                  User?             @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId                Int?
  userPrimaryEmail      String?
  references            BookingReference[]
  eventType             EventType?        @relation(fields: [eventTypeId], references: [id])
  eventTypeId           Int?
  title                 String
  description           String?
  customInputs          Json?
  /// @zod.import(["import { bookingResponses } from '../../zod-utils'"]).custom.use(bookingResponses)
  responses             Json?
  startTime             DateTime
  endTime               DateTime
  attendees             Attendee[]
  location              String?
  destinationCalendar   DestinationCalendar? @relation(fields: [destinationCalendarId], references: [id])
  destinationCalendarId Int?
  paid                  Boolean           @default(false)
  payment               Payment[]
  status                BookingStatus     @default(ACCEPTED)
  cancellationReason    String?
  rejectionReason       String?
  dynamicEventSlugRef   String?
  dynamicGroupSlugRef   String?
  rescheduled           Boolean?
  fromReschedule        String?
  recurringEventId      String?
  smsReminderNumber     String?
  scheduledJobs         String[]
  metadata              Json?
  isRecorded            Boolean           @default(false)
  seatsReferences       BookingSeat[]
  reassignById          Int?
  reassignBy            User?             @relation("reassignByUser", fields: [reassignById], references: [id], onDelete: SetNull)
  reassignReason        String?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  rating                Int?
  ratingFeedback        String?
  noShowHost            Boolean?
  oneTimePassword       String?
  cancelledBy           String?
  isTeamBooking         Boolean?          @default(false)
  bookingFieldsResponses Json?
  iCalSequence          Int               @default(0)
  iCalUID               String?
  BookingInternalNote   BookingInternalNote[]
  BookingReport         BookingReport[]
  WrongAssignmentReport WrongAssignmentReport[]
  instantMeetingToken   InstantMeetingToken?
  BookingAudit          BookingAudit[]

  // ── SaaS Barbershop fields ────────────────────────────────────────────────

  /// Чи підтверджено виконання послуги майстром (кнопка ✅ у Telegram)
  isCompleted           Boolean           @default(false)

  /// Дата і час, коли майстер натиснув ✅ Виконано
  completedAt           DateTime?

  @@index([eventTypeId])
  @@index([userId])
  @@index([destinationCalendarId])
  @@index([recurringEventId])
  @@index([uid])
  @@index([status])
  @@index([startTime])
  @@index([endTime])
  @@index([isCompleted])
}

enum BookingStatus {
  CANCELLED  @map("cancelled")
  ACCEPTED   @map("accepted")
  REJECTED   @map("rejected")
  PENDING    @map("pending")
  AWAITING_HOST @map("awaiting_host")
}

