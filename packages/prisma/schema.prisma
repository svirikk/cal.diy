  teamId      Int?
  team        Team?    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  name        String
  slug        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, slug])
  @@unique([teamId, slug])
  @@index([userId])
  @@index([teamId])
}

model OAuthClient {
  id          String    @id @default(uuid())
  name        String
  clientId    String    @unique
  clientSecret String
  redirectUris String[]
  userId      Int?
  user        User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  teamId      Int?
  team        Team?     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  webhooks    Webhook[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId])
  @@index([teamId])
}

model UserHolidaySettings {
  id         Int      @id @default(autoincrement())
  userId     Int      @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  country    String
  year       Int
  holidays   Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId])
}

model EventTypeTranslation {
  id           Int       @id @default(autoincrement())
  eventTypeId  Int
  eventType    EventType @relation(fields: [eventTypeId], references: [id], onDelete: Cascade)
  language     String
  field        String
  value        String
  createdById  Int?
  createdBy    User?     @relation("CreatedEventTypeTranslations", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById  Int?
  updatedBy    User?     @relation("UpdatedEventTypeTranslations", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([eventTypeId, language, field])
  @@index([eventTypeId])
  @@index([language])
}

model Attribute {
  id      String           @id @default(uuid())
  teamId  Int
  team    Team             @relation(fields: [teamId], references: [id], onDelete: Cascade)
  type    AttributeType
  name    String
  slug    String
  options AttributeOption[]
  attributeToUsers AttributeToUser[]
  enabled Boolean          @default(true)
  usersCanEditRelation Boolean @default(false)
  isWeightsEnabled Boolean @default(false)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@unique([teamId, slug])
  @@index([teamId])
}

enum AttributeType {
  TEXT
  NUMBER
  SINGLE_SELECT
  MULTI_SELECT
}

model AttributeOption {
  id          String           @id @default(uuid())
  attributeId String
  attribute   Attribute        @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  value       String
  slug        String
  teamId      Int?
  team        Team?            @relation(fields: [teamId], references: [id], onDelete: Cascade)
  assignedUsers AttributeToUser[]
  isGroup     Boolean          @default(false)
  contains    AttributeToUser[] @relation("GroupContains")
  group       AttributeToUser[] @relation("GroupMember")
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([attributeId, slug])
  @@index([attributeId])
  @@index([teamId])
}

model AttributeToUser {
  id              Int             @id @default(autoincrement())
  memberId        Int
  member          Membership      @relation(fields: [memberId], references: [id], onDelete: Cascade)
  attributeOption AttributeOption @relation(fields: [attributeOptionId], references: [id], onDelete: Cascade)
  attributeOptionId String
  teamId          Int?
  team            Team?           @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdById     Int?
  createdBy       User?           @relation("createdBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById     Int?
  updatedBy       User?           @relation("updatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  weight          Float?
  groupContainerAttribute AttributeOption? @relation("GroupContains", fields: [groupContainerAttributeId], references: [id], onDelete: SetNull)
  groupContainerAttributeId String?
  groupMemberOf   AttributeOption[] @relation("GroupMember")
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@unique([memberId, attributeOptionId])
  @@index([memberId])
  @@index([attributeOptionId])
  @@index([teamId])
}

model DelegationCredential {
  id                    String              @id @default(uuid())
  delegatedToId         Int
  delegatedTo           Team                @relation("DelegatedToTeam", fields: [delegatedToId], references: [id], onDelete: Cascade)
  delegatedFromId       Int
  delegatedFrom         Team                @relation("DelegatedFromTeam", fields: [delegatedFromId], references: [id], onDelete: Cascade)
  workspacePlatformSlug String
  serviceAccountKey     Json?
  enabled               Boolean             @default(true)
  credentials           Credential[]
  destinationCalendars  DestinationCalendar[]
  selectedCalendars     SelectedCalendar[]
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  @@unique([delegatedToId, workspacePlatformSlug])
  @@index([delegatedToId])
  @@index([delegatedFromId])
}

model IntegrationAttributeSync {
  id           Int        @id @default(autoincrement())
  credentialId Int
  credential   Credential @relation(fields: [credentialId], references: [id], onDelete: Cascade)
  lastSyncAt   DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([credentialId])
}

model TempOrgRedirect {
  id        Int          @id @default(autoincrement())
  from      String
  fromOrgId Int          @default(0)
  type      RedirectType
  toUrl     String
  enabled   Boolean      @default(true)
  keepQuery Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@unique([from, type, fromOrgId])
  @@index([from, type, fromOrgId])
}

model CalendarCache {
  id           String?  @default(uuid())
  key          String
  value        Json
  expiresAt    DateTime
  updatedAt    DateTime @default(now()) @updatedAt
  credentialId Int
  userId       Int?
  credential   Credential? @relation(fields: [credentialId], references: [id], onDelete: Cascade)

  @@id([credentialId, key])
  @@unique([credentialId, key])
  @@index([userId, key])
}

model BookingAudit {
  id        String   @id @default(uuid()) @db.Uuid
  bookingId Int
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  actor     AuditActor?
  action    String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([bookingId])
  @@index([createdAt])
}

model AuditActor {
  id           String       @id @default(uuid()) @db.Uuid
  auditId      String       @unique @db.Uuid
  audit        BookingAudit @relation(fields: [auditId], references: [id], onDelete: Cascade)
  type         AuditActorType
  name         String?
  email        String?
  userUuid     String?      @db.Uuid
  attendeeId   Int?
  credentialId Int?
  appSlug      String?

  @@index([auditId])
}

enum AuditActorType {
  USER     @map("user")
  ATTENDEE @map("attendee")
  APP      @map("app")
  SYSTEM   @map("system")
}

