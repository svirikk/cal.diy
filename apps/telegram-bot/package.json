{
  "name": "@barbersaas/telegram-bot",
  "version": "1.0.0",
  "private": true,
  "description": "Telegram-бот для SaaS-платформи барбершопів",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "telegraf": "4.16.3",
    "@prisma/client": "5.14.0",
    "node-cron": "3.0.3",
    "date-fns": "3.6.0",
    "dotenv": "16.4.5"
  },
  "devDependencies": {
    "@types/node": "20.14.0",
    "@types/node-cron": "3.0.11",
    "ts-node-dev": "2.0.0",
    "typescript": "5.4.5",
    "prisma": "5.14.0"
  }
}
